{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "equaledge-ai",
  "main": "src/index.js",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },

  "rules": [
    {
      "type": "Data",
      "globs": ["data/*.json"],
      "fallthrough": true
    }
  ]
}
